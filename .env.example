LITELLM_MASTER_KEY=change-me
LITELLM_API_KEY=change-me

# Même image pour api + worker (build une fois : docker build -t offline-ci-orchestrator:latest ./orchestrator)
ORCHESTRATOR_IMAGE=offline-ci-orchestrator:latest

POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=litellm
# Must match POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB (URL-encode special chars in password if needed).
LITELLM_DATABASE_URL=postgresql://litellm:change-me-db-password@postgres:5432/litellm

VLLM_HOST_MODELS_DIR=./models

VLLM_FAST_VISIBLE_DEVICES=0
VLLM_FAST_MODEL=/models/Qwen_Qwen2.5-Coder-1.5B-Instruct
VLLM_FAST_SERVED_MODEL_NAME=qwen-fast
VLLM_FAST_MAX_MODEL_LEN=8192
VLLM_FAST_GPU_MEMORY_UTILIZATION=0.70
VLLM_FAST_TENSOR_PARALLEL_SIZE=1
VLLM_FAST_DTYPE=half
VLLM_FAST_EXTRA_ARGS="--enforce-eager --enable-auto-tool-choice --tool-call-parser hermes"

# LiteLLM route name (script uses litellm/<name> for OpenCode).
OPENCODE_MODEL=chat-fast
# OpenCode provider limits (align with VLLM_FAST_MAX_MODEL_LEN; output < context).
OPENCODE_MODEL_CONTEXT=8192
OPENCODE_MODEL_MAX_OUTPUT=2048

MAX_FIX_LOOPS=5
TEST_IMAGE=offline-ci-python:3.11
TEST_COMMAND="pytest -q"
BOT_GIT_NAME=ci-agent-bot
BOT_GIT_EMAIL=ci-agent@local.lan
SANDBOX_NETWORK=none
SANDBOX_CPU_LIMIT=2
SANDBOX_MEMORY_LIMIT=4g

GITEA_WEBHOOK_SECRET=
GITEA_BASE_URL=
GITEA_TOKEN=
